<?xml version="1.0" standalone="no" ?>
<!DOCTYPE scene SYSTEM "scene.dtd">

<scene output_file="custom-dof.png">
    <background_color r="0.0" g="0.0" b="0.0"/>
    <camera>
        <position x="4.5" y="6.0" z="1.0"/>
        <lookat x="0.0" y="0.0" z="0.0"/>
        <up x="0.0" y="1.0" z="0.0"/>
        <horizontal_fov angle="45"/>
        <resolution horizontal="1024" vertical="1024"/>
        <max_bounces n="8"/>
        <render_times n="6"/>
        <dof distance="5.0" weakness="4.0"/>
    </camera>
    <lights>
        <ambient_light>
            <color r="1.0" g="1.0" b="1.0"/>
        </ambient_light>
        <spot_light>
            <color r="1.0" g="1.0" b="1.0"/>
            <position x="1.3" y="5.0" z="0.0"/>
            <direction x="-0.5" y="-1.0" z="-0.0"/>
            <falloff alpha1="5" alpha2="20"/>
        </spot_light>
        <area_light objfile="plane_small.obj">
            <color r="0.9" g="0.6" b="0.9"/>
            <transform>
                <translate x="0.0" y="6.0" z="1.0"/>
                <scale x="0.3" y="0.3" z="0.3"/>
                <rotateX theta="75.0"/>
            </transform>
        </area_light>
    </lights>
    <surfaces>
        <mesh name="gfxscene.obj">
            <material_textured>
                <texture name="gfxscene-pal.png"/>
                <phong ka="0.3" kd="0.9" ks="0.5" exponent="10"/>
                <reflectance r="0.0"/>
                <transmittance t="0.0"/>
                <refraction iof="0.0"/>
            </material_textured>
        </mesh>
        <mesh name="plane_small.obj">
            <material_textured>
                <texture name="candy-constellation-3.png"/>
                <phong ka="1.0" kd="0.0" ks="0.0" exponent="0"/>
                <reflectance r="0.0"/>
                <transmittance t="0.0"/>
                <refraction iof="0.0"/>
            </material_textured>
            <transform>
                <translate x="-18.0" y="5.0" z="-32.0"/>
                <rotateY theta="70.0"/>
                <rotateX theta="-50.0"/>
                <scale x="300.0" y="300.0" z="1.0"/>
            </transform>
        </mesh>
        <sphere radius="0.8">
            <position x="0.0" y="0.0" z="0.0"/>
            <material_solid>
                <color r="1.0" g="0.8" b="1.0"/>
                <phong ka="0.3" kd="0.9" ks="0.0" exponent="0"/>
                <reflectance r="0.0"/>
                <transmittance t="0.8"/>
                <refraction iof="2.3"/>
            </material_solid>
            <transform>
                <translate x="-1.0" y="3.0" z="-3.0"/>
            </transform>
        </sphere>
    </surfaces>
</scene>
